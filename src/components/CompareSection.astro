---
import { Code } from 'astro:components';
import { features } from '../data/features';

interface Props {
  slug: string;
  label?: string;
}

const { slug, label = 'Compare in 3 ways' } = Astro.props;

const feature = features.find((f) => f.slug === slug);
if (!feature) {
  throw new Error(`<CompareSection /> got unknown feature slug: "${slug}"`);
}

const sources = import.meta.glob('./*.{tsx,vue,svelte}', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

function load(name: string): string {
  const key = `./${name}`;
  const src = sources[key];
  if (!src) throw new Error(`Source not found: ${key}`);
  return src;
}

const reactSrc = load(feature.files.react);
const vueSrc = load(feature.files.vue);
const svelteSrc = load(feature.files.svelte);

const dialogId = `compare-${slug}`;
---

<button
  type="button"
  data-compare-trigger={dialogId}
  class="inline-flex items-center gap-1 rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-medium text-slate-600 hover:border-blue-300 hover:bg-blue-50 hover:text-blue-700"
>
  <span aria-hidden="true">{`<>`}</span>
  {label} →
</button>

<dialog
  id={dialogId}
  class="m-auto max-h-[90vh] w-[min(1280px,95vw)] rounded-lg border border-slate-200 bg-white p-0 shadow-xl backdrop:bg-black/40"
>
  <div class="flex items-start justify-between gap-4 border-b border-slate-200 px-4 py-3">
    <div>
      <p class="text-xs uppercase tracking-wider text-slate-500">{feature.concept}</p>
      <h3 class="text-lg font-semibold">{feature.title}</h3>
    </div>
    <div class="flex shrink-0 items-center gap-3">
      <a
        href={`/compare/${feature.slug}`}
        class="text-sm text-blue-700 hover:underline"
      >Open full page →</a>
      <button
        type="button"
        data-compare-close
        aria-label="Close"
        class="rounded px-2 py-1 text-slate-500 hover:bg-slate-100"
      >✕</button>
    </div>
  </div>

  <div class="overflow-y-auto p-4" style="max-height: calc(90vh - 60px);">
    <p class="mb-4 max-w-3xl text-sm text-slate-600">{feature.blurb}</p>

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
      <div class="flex flex-col overflow-hidden rounded-md border border-slate-200">
        <div class="border-b border-slate-200 bg-slate-50 px-3 py-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">React</span>
          <span class="ml-2 font-mono text-xs text-slate-400">{feature.files.react}</span>
        </div>
        <div class="overflow-x-auto p-3 text-xs">
          <Code code={reactSrc} lang="tsx" theme="github-light" />
        </div>
      </div>

      <div class="flex flex-col overflow-hidden rounded-md border border-slate-200">
        <div class="border-b border-slate-200 bg-slate-50 px-3 py-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Vue</span>
          <span class="ml-2 font-mono text-xs text-slate-400">{feature.files.vue}</span>
        </div>
        <div class="overflow-x-auto p-3 text-xs">
          <Code code={vueSrc} lang="vue" theme="github-light" />
        </div>
      </div>

      <div class="flex flex-col overflow-hidden rounded-md border border-slate-200">
        <div class="border-b border-slate-200 bg-slate-50 px-3 py-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Svelte</span>
          <span class="ml-2 font-mono text-xs text-slate-400">{feature.files.svelte}</span>
        </div>
        <div class="overflow-x-auto p-3 text-xs">
          <Code code={svelteSrc} lang="svelte" theme="github-light" />
        </div>
      </div>
    </div>
  </div>
</dialog>

<script>
  // One delegated handler for every CompareSection on the page.
  if (!(window as any).__compareSectionWired) {
    (window as any).__compareSectionWired = true;

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      const trigger = target.closest('[data-compare-trigger]');
      if (trigger) {
        const id = trigger.getAttribute('data-compare-trigger');
        if (id) {
          const dialog = document.getElementById(id) as HTMLDialogElement | null;
          dialog?.showModal();
        }
        return;
      }

      if (target.closest('[data-compare-close]')) {
        const dialog = (target.closest('dialog') as HTMLDialogElement | null);
        dialog?.close();
        return;
      }

      // Backdrop click: target IS the <dialog> element when the click
      // lands outside its content rect.
      if (target.tagName === 'DIALOG') {
        const dialog = target as HTMLDialogElement;
        const rect = dialog.getBoundingClientRect();
        const inside =
          e.clientX >= rect.left &&
          e.clientX <= rect.right &&
          e.clientY >= rect.top &&
          e.clientY <= rect.bottom;
        if (!inside) dialog.close();
      }
    });
  }
</script>
