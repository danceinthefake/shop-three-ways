---
import '../../styles/global.css';
import { Code } from 'astro:components';
import { features, type Feature } from '../../data/features';

export function getStaticPaths() {
  return features.map((f) => ({
    params: { feature: f.slug },
    props: { feature: f },
  }));
}

const { feature } = Astro.props as { feature: Feature };

const sources = import.meta.glob('../../components/*.{tsx,vue,svelte}', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

function load(name: string): string {
  const key = `../../components/${name}`;
  const src = sources[key];
  if (!src) throw new Error(`Source not found: ${key}`);
  return src;
}

const reactSrc = load(feature.files.react);
const vueSrc = load(feature.files.vue);
const svelteSrc = load(feature.files.svelte);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{feature.title} — Compare — shop-three-ways</title>
  </head>
  <body class="bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-7xl items-center gap-4 px-6 py-3 text-sm">
        <a href="/" class="text-blue-700 hover:underline">← home</a>
        <a href="/compare" class="text-blue-700 hover:underline">all comparisons</a>
        <a href="/shop" class="text-blue-700 hover:underline">shop</a>
        <a href="/cart" class="text-blue-700 hover:underline">cart</a>
        <a href="/about" class="text-blue-700 hover:underline">about</a>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-6 py-8">
      <p class="mb-1 text-xs uppercase tracking-wider text-slate-500">{feature.concept}</p>
      <h1 class="mb-2 text-3xl font-bold">{feature.title}</h1>
      <p class="mb-8 max-w-3xl text-slate-600">{feature.blurb}</p>

      <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
        <div class="flex flex-col overflow-hidden rounded-lg border border-slate-200 bg-white">
          <div class="border-b border-slate-200 px-3 py-2">
            <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">React</span>
            <span class="ml-2 font-mono text-xs text-slate-400">{feature.files.react}</span>
          </div>
          <div class="overflow-x-auto p-3 text-xs">
            <Code code={reactSrc} lang="tsx" theme="github-light" />
          </div>
        </div>

        <div class="flex flex-col overflow-hidden rounded-lg border border-slate-200 bg-white">
          <div class="border-b border-slate-200 px-3 py-2">
            <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Vue</span>
            <span class="ml-2 font-mono text-xs text-slate-400">{feature.files.vue}</span>
          </div>
          <div class="overflow-x-auto p-3 text-xs">
            <Code code={vueSrc} lang="vue" theme="github-light" />
          </div>
        </div>

        <div class="flex flex-col overflow-hidden rounded-lg border border-slate-200 bg-white">
          <div class="border-b border-slate-200 px-3 py-2">
            <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Svelte</span>
            <span class="ml-2 font-mono text-xs text-slate-400">{feature.files.svelte}</span>
          </div>
          <div class="overflow-x-auto p-3 text-xs">
            <Code code={svelteSrc} lang="svelte" theme="github-light" />
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
