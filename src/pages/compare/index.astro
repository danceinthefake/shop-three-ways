---
import '../../styles/global.css';
import { features } from '../../data/features';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Compare — shop-three-ways</title>
  </head>
  <body class="bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-5xl items-center gap-4 px-6 py-3 text-sm">
        <a href="/" class="text-blue-700 hover:underline">← home</a>
        <a href="/shop" class="text-blue-700 hover:underline">shop</a>
        <a href="/cart" class="text-blue-700 hover:underline">cart</a>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 py-8">
      <h1 class="mb-2 text-3xl font-bold">Compare</h1>
      <p class="mb-8 text-slate-600">
        Pick a feature to read its React, Vue, and Svelte implementations
        side-by-side. Each page shows the actual source files used by the
        live shop, highlighted with Shiki.
      </p>

      <ul class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {features.map((f) => (
          <li>
            <a
              href={`/compare/${f.slug}`}
              class="block rounded-lg border border-slate-200 bg-white p-4 hover:border-blue-300 hover:bg-blue-50"
            >
              <div class="flex items-baseline justify-between gap-2">
                <h2 class="text-lg font-semibold">{f.title}</h2>
                <span class="text-xs uppercase tracking-wider text-slate-500">{f.concept}</span>
              </div>
              <p class="mt-2 text-sm text-slate-600">{f.blurb}</p>
            </a>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
