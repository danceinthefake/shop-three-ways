---
import Layout from '../../layouts/Layout.astro';
import { features } from '../../data/features';
---

<Layout title="Compare — shop-three-ways" withCart={false}>
  <main class="mx-auto max-w-5xl px-6 py-8">
    <h1 class="mb-2 text-3xl font-bold">Compare</h1>
    <p class="mb-8 text-slate-600 dark:text-slate-300">
      Pick a feature to read its React, Vue, and Svelte implementations
      side-by-side. Each page shows the actual source files used by the
      live shop, highlighted with Shiki.
    </p>

    <ul class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {features.map((f) => (
        <li>
          <a
            href={`/compare/${f.slug}`}
            class="block rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-4 hover:border-blue-300 dark:hover:border-blue-600 hover:bg-blue-50 dark:hover:bg-blue-950/30"
          >
            <div class="flex items-baseline justify-between gap-2">
              <h2 class="text-lg font-semibold">{f.title}</h2>
              <span class="text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400">{f.concept}</span>
            </div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{f.blurb}</p>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Layout>
