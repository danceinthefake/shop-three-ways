---
import '../styles/global.css';
import HelloReact from '../components/HelloReact.tsx';
import HelloVue from '../components/HelloVue.vue';
import HelloSvelte from '../components/HelloSvelte.svelte';
import SlideBannerReact from '../components/SlideBannerReact.tsx';
import SlideBannerVue from '../components/SlideBannerVue.vue';
import SlideBannerSvelte from '../components/SlideBannerSvelte.svelte';
import ProductCarouselReact from '../components/ProductCarouselReact.tsx';
import ProductCarouselVue from '../components/ProductCarouselVue.vue';
import ProductCarouselSvelte from '../components/ProductCarouselSvelte.svelte';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>shop-three-ways</title>
	</head>
	<body class="bg-slate-50 text-slate-900">
		<main class="mx-auto max-w-5xl px-6 py-8">
			<h1 class="mb-2 text-3xl font-bold">shop-three-ways</h1>
			<p class="mb-4 text-slate-600">
				The same shop, built three times — in React, Vue, and Svelte.
			</p>
			<p class="mb-8 flex flex-wrap gap-4">
				<a href="/shop" class="text-blue-700 hover:underline">→ Visit the shop</a>
				<a href="/cart" class="text-blue-700 hover:underline">→ View the cart</a>
				<a href="/compare" class="text-blue-700 hover:underline">→ Compare source code</a>
			</p>

			<section class="mb-10">
				<h2 class="mb-1 text-xl font-semibold">Hero slide banner — three timers, three cleanup idioms</h2>
				<p class="mb-4 text-sm text-slate-600">
					Each banner advances every 3 seconds. Watch what happens when you
					navigate away (route change unmounts the components and each framework's
					cleanup fires — no orphan intervals).
				</p>
				<div class="grid grid-cols-1 gap-4 md:grid-cols-3">
					<div class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-wider text-slate-500">React (useEffect)</span>
						<SlideBannerReact client:load />
					</div>
					<div class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Vue (onMounted/onUnmounted)</span>
						<SlideBannerVue client:load />
					</div>
					<div class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Svelte ($effect)</span>
						<SlideBannerSvelte client:load />
					</div>
				</div>
			</section>

			<section class="mb-10">
				<h2 class="mb-1 text-xl font-semibold">Featured carousel — three ways to grab a DOM element</h2>
				<p class="mb-4 text-sm text-slate-600">
					The prev/next buttons call <code>scrollBy()</code> on the underlying
					scroll container. Each framework has its own way to capture that
					element from the template.
				</p>
				<div class="flex flex-col gap-6">
					<div class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-wider text-slate-500">React (useRef)</span>
						<ProductCarouselReact client:load />
					</div>
					<div class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Vue (template ref)</span>
						<ProductCarouselVue client:load />
					</div>
					<div class="flex flex-col gap-2">
						<span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Svelte (bind:this)</span>
						<ProductCarouselSvelte client:load />
					</div>
				</div>
			</section>

			<section>
				<h2 class="mb-2 text-xl font-semibold">Hydration smoke test</h2>
				<p class="mb-4 text-slate-600">Click each + button. If all three increment, hydration works.</p>
				<div class="flex flex-col gap-2">
					<HelloReact client:load />
					<HelloVue client:load />
					<HelloSvelte client:load />
				</div>
			</section>
		</main>
	</body>
</html>
