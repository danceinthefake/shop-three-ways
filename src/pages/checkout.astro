---
import '../styles/global.css';
import CheckoutFormReact from '../components/CheckoutFormReact.tsx';
import CheckoutFormVue from '../components/CheckoutFormVue.vue';
import CheckoutFormSvelte from '../components/CheckoutFormSvelte.svelte';
import CartBadgeReact from '../components/CartBadgeReact.tsx';
import CartBadgeVue from '../components/CartBadgeVue.vue';
import CartBadgeSvelte from '../components/CartBadgeSvelte.svelte';
import CompareSection from '../components/CompareSection.astro';
import ToasterReact from '../components/ToasterReact.tsx';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Checkout — shop-three-ways</title>
  </head>
  <body class="bg-slate-50 text-slate-900">
    <header class="sticky top-0 z-10 border-b border-slate-200 bg-white/80 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3">
        <div class="flex gap-3 text-sm">
          <a href="/" class="text-blue-700 hover:underline">← home</a>
          <a href="/shop" class="text-blue-700 hover:underline">shop</a>
          <a href="/cart" class="text-blue-700 hover:underline">cart</a>
          <a href="/compare" class="text-blue-700 hover:underline">compare</a>
          <a href="/about" class="text-blue-700 hover:underline">about</a>
          <a href="/glossary" class="text-blue-700 hover:underline">glossary</a>
        </div>
        <div class="flex items-center gap-2">
          <span class="mr-1 text-xs text-slate-500">Cart (synced):</span>
          <CartBadgeReact client:load />
          <CartBadgeVue client:load />
          <CartBadgeSvelte client:load />
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 py-8">
      <div class="mb-2 flex flex-wrap items-baseline justify-between gap-3">
        <h1 class="text-3xl font-bold">Checkout</h1>
        <CompareSection slug="checkout-form" label="CheckoutForm" />
      </div>
      <p class="mb-8 text-slate-600">
        Three independent forms with the same fields and the same validation
        rules. The interesting code is how each framework structures
        per-field state, derives the error map, and gates the submit button.
        No real backend — submitting just flips an inline success state.
      </p>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <section class="rounded-lg border border-slate-200 bg-white p-4">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-500">React (useState + useMemo)</h2>
          <CheckoutFormReact client:load />
        </section>
        <section class="rounded-lg border border-slate-200 bg-white p-4">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-500">Vue (ref + computed)</h2>
          <CheckoutFormVue client:load />
        </section>
        <section class="rounded-lg border border-slate-200 bg-white p-4">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-500">Svelte ($state + $derived)</h2>
          <CheckoutFormSvelte client:load />
        </section>
      </div>
    </main>

    <ToasterReact client:load />
  </body>
</html>
