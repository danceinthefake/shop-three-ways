---
import Layout from '../layouts/Layout.astro';
import CheckoutFormReact from '../components/CheckoutFormReact.tsx';
import CheckoutFormVue from '../components/CheckoutFormVue.vue';
import CheckoutFormSvelte from '../components/CheckoutFormSvelte.svelte';
import CompareSection from '../components/CompareSection.astro';
---

<Layout title="Checkout — shop-three-ways" stickyHeader>
  <main class="mx-auto max-w-5xl px-6 py-8">
    <div class="mb-2 flex flex-wrap items-baseline justify-between gap-3">
      <h1 class="text-3xl font-bold">Checkout</h1>
      <div class="flex flex-wrap gap-2">
        <CompareSection slug="checkout-form" label="CheckoutForm" />
        <CompareSection slug="use-cart" label="useCart" />
      </div>
    </div>
    <p class="mb-8 text-slate-600 dark:text-slate-300">
      Three independent forms with the same fields and the same validation
      rules. The interesting code is how each framework structures
      per-field state, derives the error map, and gates the submit button.
      No real backend — submitting just flips an inline success state.
    </p>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
      <section class="rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-4">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">React (useState + useMemo)</h2>
        <CheckoutFormReact client:load />
      </section>
      <section class="rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-4">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Vue (ref + computed)</h2>
        <CheckoutFormVue client:load />
      </section>
      <section class="rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-4">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Svelte ($state + $derived)</h2>
        <CheckoutFormSvelte client:load />
      </section>
    </div>
  </main>
</Layout>
