---
import '../styles/global.css';
import ProductListReact from '../components/ProductListReact.tsx';
import ProductListVue from '../components/ProductListVue.vue';
import ProductListSvelte from '../components/ProductListSvelte.svelte';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Shop — shop-three-ways</title>
  </head>
  <body class="bg-slate-50 text-slate-900">
    <main class="mx-auto max-w-5xl px-6 py-8">
      <p class="mb-4"><a href="/" class="text-blue-700 hover:underline">← home</a></p>
      <h1 class="mb-2 text-3xl font-bold">Shop</h1>
      <p class="mb-8 text-slate-600">
        The same product list, fetched from the
        <a href="https://fakeapi.platzi.com/" class="text-blue-700 hover:underline">Platzi Fake Store API</a>
        and rendered three times — each block is the same data through a different framework.
      </p>

      <section class="my-6 rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-500">React</h2>
        <ProductListReact client:load />
      </section>

      <section class="my-6 rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-500">Vue</h2>
        <ProductListVue client:load />
      </section>

      <section class="my-6 rounded-lg border border-slate-200 bg-white p-4">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-500">Svelte</h2>
        <ProductListSvelte client:load />
      </section>
    </main>
  </body>
</html>
